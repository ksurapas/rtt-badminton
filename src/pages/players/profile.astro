---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Player Profile">
  <section class="hero-banner" id="hero-banner">
    <div class="hero-gradient"></div>
    <div class="hero-content">
      <div class="hero-photo-wrapper">
        <img id="hero-photo" src="" alt="Player profile photo" class="hero-photo" />
        <button type="button" id="edit-photo-btn" class="edit-photo-btn" title="Change profile picture" hidden>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
            <circle cx="12" cy="13" r="4"/>
          </svg>
        </button>
        <input type="file" id="edit-photo-input" accept="image/jpeg,image/png,image/webp" style="display:none" />
      </div>
      <div class="hero-name-row">
        <h1 class="hero-name" id="hero-name"></h1>
        <button type="button" id="edit-name-btn" class="edit-name-btn" title="Edit player name" hidden>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
          </svg>
        </button>
      </div>
      <div id="name-edit-row" class="name-edit-row" hidden>
        <input type="text" id="name-edit-input" class="name-edit-input" maxlength="60" />
        <button type="button" id="save-name-btn" class="btn-save-name">Save</button>
        <button type="button" id="cancel-name-btn" class="btn-cancel-name">Cancel</button>
      </div>
    </div>
  </section>

  <div id="photo-edit-panel" class="photo-edit-panel" hidden>
    <img id="photo-edit-preview" class="photo-edit-preview" alt="New profile picture preview" />
    <div class="photo-edit-actions">
      <button type="button" id="save-photo-btn" class="btn-save-photo">Save Photo</button>
      <button type="button" id="cancel-photo-btn" class="btn-cancel-photo">Cancel</button>
    </div>
    <span id="photo-edit-error" class="photo-edit-error"></span>
  </div>

  <section class="stats-row" id="stats-row">
    <div class="stat-card">
      <span class="stat-value" id="stat-mmr">—</span>
      <span class="stat-label">MMR</span>
    </div>
    <div class="stat-card">
      <span class="stat-value" id="stat-rank">—</span>
      <span class="stat-label">Rank</span>
    </div>
    <div class="stat-card">
      <span class="stat-value" id="stat-record">—</span>
      <span class="stat-label">W / L</span>
    </div>
  </section>

  <section class="match-history-section">
    <h2>Match History</h2>
    <div id="match-history">
      <p class="empty-state" id="empty-history">Loading…</p>
    </div>
  </section>

  <section class="h2h-section" id="h2h-section" hidden>
    <h2>Head-to-Head</h2>
    <div id="h2h-list"></div>
  </section>

  <section class="partnership-section" id="partnership-section" hidden>
    <h2>Doubles Partnerships</h2>
    <div id="partnership-list"></div>
  </section>

  <section class="danger-zone" id="danger-zone" hidden>
    <h2>Danger Zone</h2>
    <p>Permanently remove this player and all their data.</p>
    <button type="button" id="delete-player-btn" class="btn-delete">Delete Player</button>
  </section>

  <div id="not-found" class="not-found" hidden>
    <h2>Player not found</h2>
    <p>The player you're looking for doesn't exist.</p>
    <a href={`${import.meta.env.BASE_URL}players/`} class="btn-back">← Back to Players</a>
  </div>
</Layout>

<script>
  import { loadData, saveData, savePlayers, waitForData, loadPlayerPhoto, savePlayerPhoto, deletePlayerPhoto } from '../../lib/storage-service';
  import { sortPlayersByRanking, getMatchHistoryForPlayer } from '../../lib/ranking';
  import { formatDate, DEFAULT_PLACEHOLDER_IMAGE, compressImage } from '../../lib/utils';
  import type { Player, MatchRecord } from '../../lib/types';

  function formatBWFName(fullName: string): string {
    const parts = fullName.trim().split(/\s+/);
    if (parts.length <= 1) return fullName.toUpperCase();
    const lastName = parts[parts.length - 1].toUpperCase();
    const firstNames = parts.slice(0, -1).join(' ');
    return `${firstNames} ${lastName}`;
  }

  function getPlayerName(id: string, players: Player[]): string {
    return players.find((p) => p.id === id)?.name ?? 'Unknown';
  }

  function getMMRDelta(playerId: string, match: MatchRecord): number {
    return match.mmrChanges.find((c) => c.playerId === playerId)?.delta ?? 0;
  }

  function didPlayerWin(playerId: string, match: MatchRecord): boolean {
    const winningTeam = match.winner === 'teamA' ? match.teamA : match.teamB;
    return winningTeam.includes(playerId);
  }

  function getOpponentIds(playerId: string, match: MatchRecord): string[] {
    if (match.teamA.includes(playerId)) return match.teamB;
    return match.teamA;
  }

  // ── Extract player ID from query parameter ────────────────
  const params = new URLSearchParams(window.location.search);
  const playerId = params.get('id') ?? '';

  await waitForData();

  const heroBanner = document.getElementById('hero-banner')!;
  const heroPhoto = document.getElementById('hero-photo') as HTMLImageElement;
  const heroName = document.getElementById('hero-name')!;
  const statMmr = document.getElementById('stat-mmr')!;
  const statRank = document.getElementById('stat-rank')!;
  const statRecord = document.getElementById('stat-record')!;
  const statsRow = document.getElementById('stats-row')!;
  const matchHistoryContainer = document.getElementById('match-history')!;
  const emptyHistory = document.getElementById('empty-history')!;
  const notFound = document.getElementById('not-found')!;
  const historySection = document.querySelector('.match-history-section') as HTMLElement;

  const data = loadData();
  const player = data.players.find((p) => p.id === playerId);

  if (!player) {
    heroBanner.hidden = true;
    statsRow.hidden = true;
    historySection.hidden = true;
    notFound.hidden = false;
  } else {
    // Show placeholder immediately, then swap in the real photo when it arrives
    heroPhoto.src = DEFAULT_PLACEHOLDER_IMAGE;
    heroPhoto.alt = `${player.name} profile photo`;
    loadPlayerPhoto(playerId).then((url) => {
      if (url) heroPhoto.src = url;
    });
    heroName.textContent = formatBWFName(player.name);

    const ranked = sortPlayersByRanking(data.players);
    const rankPosition = ranked.findIndex((p) => p.id === playerId) + 1;

    statMmr.textContent = String(player.mmr);
    statRank.textContent = `#${rankPosition}`;
    statRecord.textContent = `${player.wins} / ${player.losses}`;

    const matches = getMatchHistoryForPlayer(playerId, data.matches);

    if (matches.length === 0) {
      emptyHistory.textContent = 'No matches played yet.';
    } else {
      emptyHistory.hidden = true;
      matches.forEach((match) => {
        const won = didPlayerWin(playerId, match);
        const delta = getMMRDelta(playerId, match);
        const opponentIds = getOpponentIds(playerId, match);
        const opponentNames = opponentIds.map((id) => getPlayerName(id, data.players)).join(' & ');
        const modeLabel = match.mode === 'doubles' ? 'Doubles' : 'Singles';
        const deltaStr = delta >= 0 ? `+${delta}` : String(delta);

        const row = document.createElement('div');
        row.className = `match-row ${won ? 'match-win' : 'match-loss'}`;
        row.innerHTML = `
          <div class="match-date">${formatDate(match.date)}</div>
          <div class="match-mode">${modeLabel}</div>
          <div class="match-opponents">vs ${opponentNames}</div>
          <div class="match-result">${won ? 'Win' : 'Loss'}</div>
          <div class="match-delta ${delta >= 0 ? 'delta-positive' : 'delta-negative'}">${deltaStr}</div>
        `;
        matchHistoryContainer.appendChild(row);
      });
    }

    // ── Head-to-Head stats ────────────────────────────────
    const h2hSection = document.getElementById('h2h-section')!;
    const h2hList = document.getElementById('h2h-list')!;

    if (matches.length > 0) {
      const h2h: Record<string, { wins: number; losses: number }> = {};
      matches.forEach((match) => {
        const won = didPlayerWin(playerId, match);
        getOpponentIds(playerId, match).forEach((oppId) => {
          if (!h2h[oppId]) h2h[oppId] = { wins: 0, losses: 0 };
          if (won) h2h[oppId].wins++;
          else h2h[oppId].losses++;
        });
      });

      const sortedH2H = Object.entries(h2h).sort(
        (a, b) => (b[1].wins + b[1].losses) - (a[1].wins + a[1].losses)
      );

      if (sortedH2H.length > 0) {
        h2hSection.hidden = false;
        sortedH2H.forEach(([oppId, record]) => {
          const oppName = getPlayerName(oppId, data.players);
          const total = record.wins + record.losses;
          const winPct = Math.round((record.wins / total) * 100);
          const row = document.createElement('div');
          row.className = 'h2h-row';
          row.innerHTML = `
            <span class="h2h-name">${oppName}</span>
            <span class="h2h-wins">${record.wins}W</span>
            <span class="h2h-sep">/</span>
            <span class="h2h-losses">${record.losses}L</span>
            <span class="h2h-pct ${winPct >= 50 ? 'pct-win' : 'pct-loss'}">${winPct}%</span>
          `;
          h2hList.appendChild(row);
        });
      }
    }

    // ── Doubles Partnerships ──────────────────────────────
    const partnershipSection = document.getElementById('partnership-section')!;
    const partnershipList = document.getElementById('partnership-list')!;

    const doubleMatches = matches.filter((m) => m.mode === 'doubles');
    if (doubleMatches.length > 0) {
      const partnerships: Record<string, { wins: number; losses: number }> = {};
      doubleMatches.forEach((match) => {
        const myTeam = match.teamA.includes(playerId) ? match.teamA : match.teamB;
        const partner = myTeam.find((id) => id !== playerId);
        if (!partner) return;
        if (!partnerships[partner]) partnerships[partner] = { wins: 0, losses: 0 };
        if (didPlayerWin(playerId, match)) partnerships[partner].wins++;
        else partnerships[partner].losses++;
      });

      const sortedPartners = Object.entries(partnerships).sort((a, b) => {
        const rateA = a[1].wins / (a[1].wins + a[1].losses);
        const rateB = b[1].wins / (b[1].wins + b[1].losses);
        if (rateB !== rateA) return rateB - rateA;
        return (b[1].wins + b[1].losses) - (a[1].wins + a[1].losses);
      });

      partnershipSection.hidden = false;
      sortedPartners.forEach(([partnerId, record]) => {
        const partnerPlayer = data.players.find((p) => p.id === partnerId);
        const partnerName = partnerPlayer?.name ?? 'Unknown';
        const total = record.wins + record.losses;
        const winPct = Math.round((record.wins / total) * 100);

        const card = document.createElement('div');
        card.className = 'partnership-card';

        const img = document.createElement('img');
        img.className = 'partnership-photo';
        img.alt = partnerName;
        img.src = partnerPlayer?.profilePicture ?? DEFAULT_PLACEHOLDER_IMAGE;

        const info = document.createElement('div');
        info.className = 'partnership-info';
        info.innerHTML = `
          <span class="partnership-name">${formatBWFName(partnerName)}</span>
          <span class="partnership-record">${record.wins}W / ${record.losses}L</span>
        `;

        const pct = document.createElement('span');
        pct.className = `partnership-pct ${winPct >= 50 ? 'pct-win' : 'pct-loss'}`;
        pct.textContent = `${winPct}%`;

        card.appendChild(img);
        card.appendChild(info);
        card.appendChild(pct);
        partnershipList.appendChild(card);
      });
    }

    // ── Edit profile picture ──────────────────────────────
    const editPhotoBtn = document.getElementById('edit-photo-btn')!;
    const editPhotoInput = document.getElementById('edit-photo-input') as HTMLInputElement;
    const photoEditPanel = document.getElementById('photo-edit-panel')!;
    const photoEditPreview = document.getElementById('photo-edit-preview') as HTMLImageElement;
    const savePhotoBtn = document.getElementById('save-photo-btn')!;
    const cancelPhotoBtn = document.getElementById('cancel-photo-btn')!;
    const photoEditError = document.getElementById('photo-edit-error')!;

    const MAX_FILE_SIZE = 5 * 1024 * 1024;
    const ALLOWED_TYPES = ['image/jpeg', 'image/png', 'image/webp'];
    let pendingPhotoDataUrl: string | null = null;

    function readFileAsDataUrl(file: File): Promise<string> {
      return new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onload = () => resolve(reader.result as string);
        reader.onerror = () => reject(new Error('Failed to read file'));
        reader.readAsDataURL(file);
      });
    }

    editPhotoBtn.hidden = false;
    editPhotoBtn.addEventListener('click', () => editPhotoInput.click());

    // ── Edit player name ──────────────────────────────────
    const editNameBtn = document.getElementById('edit-name-btn')!;
    const nameEditRow = document.getElementById('name-edit-row')!;
    const nameEditInput = document.getElementById('name-edit-input') as HTMLInputElement;
    const saveNameBtn = document.getElementById('save-name-btn')!;
    const cancelNameBtn = document.getElementById('cancel-name-btn')!;

    editNameBtn.hidden = false;

    editNameBtn.addEventListener('click', () => {
      nameEditInput.value = player.name;
      heroName.hidden = true;
      editNameBtn.hidden = true;
      nameEditRow.hidden = false;
      nameEditInput.focus();
      nameEditInput.select();
    });

    saveNameBtn.addEventListener('click', () => {
      const newName = nameEditInput.value.trim();
      if (!newName) return;
      const freshData = loadData();
      const target = freshData.players.find((p) => p.id === playerId);
      if (!target) return;
      target.name = newName;
      player.name = newName;
      savePlayers(freshData.players);
      heroName.textContent = formatBWFName(newName);
      heroName.hidden = false;
      editNameBtn.hidden = false;
      nameEditRow.hidden = true;
    });

    cancelNameBtn.addEventListener('click', () => {
      nameEditRow.hidden = true;
      heroName.hidden = false;
      editNameBtn.hidden = false;
    });

    editPhotoInput.addEventListener('change', async () => {
      photoEditError.textContent = '';
      const file = editPhotoInput.files?.[0];
      if (!file) return;

      if (!ALLOWED_TYPES.includes(file.type)) {
        photoEditError.textContent = 'Invalid format. Please use JPEG, PNG, or WebP.';
        editPhotoInput.value = '';
        return;
      }
      if (file.size > MAX_FILE_SIZE) {
        photoEditError.textContent = 'File too large. Maximum size is 5 MB.';
        editPhotoInput.value = '';
        return;
      }

      try {
        const raw = await readFileAsDataUrl(file);
        pendingPhotoDataUrl = await compressImage(raw);
        photoEditPreview.src = pendingPhotoDataUrl;
        photoEditPanel.hidden = false;
      } catch {
        photoEditError.textContent = 'Could not read the image file.';
      }
    });

    savePhotoBtn.addEventListener('click', async () => {
      if (!pendingPhotoDataUrl) return;
      savePhotoBtn.disabled = true;
      savePhotoBtn.textContent = 'Saving…';
      photoEditError.textContent = '';
      try {
        await savePlayerPhoto(playerId, pendingPhotoDataUrl);
        heroPhoto.src = pendingPhotoDataUrl;
        photoEditPanel.hidden = true;
        pendingPhotoDataUrl = null;
        editPhotoInput.value = '';
      } catch {
        photoEditError.textContent = 'Save failed. Please try again.';
      }
      savePhotoBtn.disabled = false;
      savePhotoBtn.textContent = 'Save Photo';
    });

    cancelPhotoBtn.addEventListener('click', () => {
      photoEditPanel.hidden = true;
      pendingPhotoDataUrl = null;
      editPhotoInput.value = '';
      photoEditError.textContent = '';
    });

    // ── Show danger zone ──────────────────────────────────
    const dangerZone = document.getElementById('danger-zone')!;
    dangerZone.hidden = false;

    const deleteBtn = document.getElementById('delete-player-btn')!;
    const BASE = import.meta.env.BASE_URL;
    deleteBtn.addEventListener('click', async () => {
      const confirmed = confirm(`Are you sure you want to delete ${player.name}? This cannot be undone.`);
      if (!confirmed) return;

      deleteBtn.disabled = true;
      deleteBtn.textContent = 'Deleting…';
      const freshData = loadData();
      freshData.players = freshData.players.filter((p) => p.id !== playerId);
      freshData.matches = freshData.matches.filter(
        (m) => !m.teamA.includes(playerId) && !m.teamB.includes(playerId)
      );
      await Promise.all([saveData(freshData), deletePlayerPhoto(playerId)]);
      window.location.href = `${BASE}players/`;
    });
  }
</script>

<style is:global>
  .hero-banner { position: relative; border-radius: 16px; overflow: hidden; margin-bottom: 1.5rem; }
  .hero-gradient { background: linear-gradient(135deg, #0d3311 0%, #1b5e20 40%, #43a047 100%); height: 180px; }
  .hero-content { display: flex; flex-direction: column; align-items: center; margin-top: -70px; padding-bottom: 1.5rem; position: relative; z-index: 1; }
  .hero-photo-wrapper { margin-bottom: 0.75rem; position: relative; display: inline-block; }
  .hero-photo { width: 140px; height: 140px; border-radius: 50%; object-fit: cover; border: 4px solid #fff; box-shadow: 0 4px 16px rgba(0,0,0,0.18); background: var(--color-bg, #f5f7f5); display: block; }
  .edit-photo-btn { position: absolute; bottom: 4px; right: 4px; width: 32px; height: 32px; border-radius: 50%; background: #1b5e20; color: #fff; border: 2px solid #fff; display: flex; align-items: center; justify-content: center; cursor: pointer; box-shadow: 0 2px 6px rgba(0,0,0,0.25); transition: background 0.2s, transform 0.15s; padding: 0; }
  .edit-photo-btn:hover { background: #2e7d32; transform: scale(1.1); }
  .photo-edit-panel:not([hidden]) { display: flex; flex-direction: column; align-items: center; gap: 0.75rem; margin-bottom: 1.5rem; background: var(--color-surface, #fff); border: 1px solid var(--color-border, #dde5dd); border-radius: 12px; padding: 1.25rem 1.5rem; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
  .photo-edit-preview { width: 90px; height: 90px; border-radius: 50%; object-fit: cover; border: 3px solid #1b5e20; }
  .photo-edit-actions { display: flex; gap: 0.5rem; }
  .btn-save-photo { background: #1b5e20; color: #fff; border: none; padding: 0.45rem 1rem; border-radius: 7px; font-weight: 600; font-size: 0.88rem; cursor: pointer; transition: background 0.2s; }
  .btn-save-photo:hover { background: #2e7d32; }
  .btn-cancel-photo { background: transparent; color: var(--color-text-light, #555); border: 1px solid var(--color-border, #dde5dd); padding: 0.45rem 1rem; border-radius: 7px; font-weight: 600; font-size: 0.88rem; cursor: pointer; transition: background 0.2s; }
  .btn-cancel-photo:hover { background: var(--color-border, #dde5dd); }
  .photo-edit-error { color: #c62828; font-size: 0.82rem; min-height: 1em; }
  .hero-name { font-size: 1.75rem; font-weight: 700; color: var(--color-text, #1a1a1a); text-align: center; margin: 0; }
  .stats-row { display: flex; justify-content: center; gap: 1.25rem; margin-bottom: 2rem; flex-wrap: wrap; }
  .stat-card { background: var(--color-surface, #fff); border: 1px solid var(--color-border, #dde5dd); border-radius: 12px; padding: 1rem 1.75rem; text-align: center; min-width: 120px; box-shadow: 0 2px 6px rgba(0,0,0,0.06); }
  .stat-value { display: block; font-size: 1.5rem; font-weight: 700; color: var(--color-primary, #1b5e20); line-height: 1.2; }
  .stat-label { display: block; font-size: 0.8rem; color: var(--color-text-light, #555); text-transform: uppercase; letter-spacing: 0.05em; margin-top: 0.25rem; }
  .match-history-section { margin-bottom: 2rem; }
  .match-history-section h2 { font-size: 1.25rem; color: var(--color-primary, #1b5e20); margin-bottom: 1rem; }
  .empty-state { text-align: center; color: var(--color-text-light, #555); padding: 2rem 0; font-size: 0.95rem; }
  .match-row { display: grid; grid-template-columns: 110px 80px 1fr auto auto; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem; background: var(--color-surface, #fff); border: 1px solid var(--color-border, #dde5dd); border-radius: 8px; margin-bottom: 0.5rem; font-size: 0.9rem; transition: box-shadow 0.15s; }
  .match-row:hover { box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
  .match-win { border-left: 4px solid var(--color-primary, #1b5e20); }
  .match-loss { border-left: 4px solid #c62828; }
  .match-date { color: var(--color-text-light, #555); font-size: 0.85rem; }
  .match-mode { font-weight: 600; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.03em; color: var(--color-text-light, #555); }
  .match-opponents { font-weight: 500; }
  .match-result { font-weight: 700; font-size: 0.85rem; text-transform: uppercase; }
  .match-win .match-result { color: var(--color-primary, #1b5e20); }
  .match-loss .match-result { color: #c62828; }
  .match-delta { font-weight: 700; font-size: 0.9rem; min-width: 50px; text-align: right; }
  .delta-positive { color: var(--color-primary, #1b5e20); }
  .delta-negative { color: #c62828; }
  .not-found { text-align: center; padding: 3rem 1rem; }
  .not-found h2 { font-size: 1.5rem; color: var(--color-text, #1a1a1a); margin-bottom: 0.5rem; }
  .not-found p { color: var(--color-text-light, #555); margin-bottom: 1.5rem; }
  .btn-back { display: inline-block; background: var(--color-primary, #1b5e20); color: #fff; text-decoration: none; padding: 0.6rem 1.25rem; border-radius: 8px; font-weight: 600; font-size: 0.9rem; transition: background 0.2s; }
  .btn-back:hover { background: var(--color-primary-light, #2e7d32); }
  .danger-zone { margin-top: 2rem; padding: 1.25rem; border: 1px solid #e57373; border-radius: 10px; background: #fff5f5; }
  .danger-zone h2 { font-size: 1rem; color: #c62828; margin-bottom: 0.35rem; }
  .danger-zone p { font-size: 0.9rem; color: var(--color-text-light, #555); margin-bottom: 1rem; }
  .btn-delete { background: #c62828; color: #fff; border: none; padding: 0.6rem 1.25rem; border-radius: 8px; font-weight: 600; font-size: 0.9rem; cursor: pointer; transition: background 0.2s; }
  .btn-delete:hover { background: #b71c1c; }
  /* ── Edit name ──────────────────────────────────────────── */
  .hero-name-row { display: flex; align-items: center; justify-content: center; gap: 0.5rem; }
  .edit-name-btn:not([hidden]) { background: transparent; border: none; color: #888; cursor: pointer; padding: 0.2rem; border-radius: 4px; display: flex; align-items: center; transition: color 0.2s; flex-shrink: 0; }
  .edit-name-btn:hover { color: #333; }
