---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Players">
  <section class="page-header">
    <h1>👥 Players</h1>
    <p class="subtitle">Manage your club's player roster</p>
  </section>

  <!-- Search bar -->
  <div class="search-bar">
    <input
      type="text"
      id="player-search"
      placeholder="Search players by name…"
      aria-label="Search players by name"
      autocomplete="off"
    />
  </div>

  <!-- Player card grid (populated client-side) -->
  <div id="player-grid" class="player-grid">
    <p class="empty-state" id="empty-state">No players yet. Add your first player below!</p>
  </div>

  <!-- Add Player form -->
  <section class="add-player-section">
    <h2>Add Player</h2>
    <form id="add-player-form" novalidate>
      <div class="form-group">
        <label for="player-name">Player Name</label>
        <input
          type="text"
          id="player-name"
          placeholder="e.g. Viktor Axelsen"
          required
          autocomplete="off"
        />
        <span class="error-msg" id="name-error" role="alert"></span>
      </div>

      <div class="form-group">
        <label for="player-photo">Profile Picture <span class="optional">(optional)</span></label>
        <input
          type="file"
          id="player-photo"
          accept="image/jpeg,image/png,image/webp"
        />
        <span class="file-hint">JPEG, PNG, or WebP — max 5 MB</span>
        <span class="error-msg" id="photo-error" role="alert"></span>
        <div id="photo-preview" class="photo-preview" hidden>
          <img id="photo-preview-img" alt="Profile picture preview" />
        </div>
      </div>

      <button type="submit" class="btn-primary">Add Player</button>
    </form>
  </section>
</Layout>

<script>
  import { loadData, savePlayers } from '../../lib/storage-service';
  import { getInitialMMR } from '../../lib/mmr-engine';
  import { generateId, DEFAULT_PLACEHOLDER_IMAGE } from '../../lib/utils';
  import type { Player } from '../../lib/types';

  const MAX_FILE_SIZE = 5 * 1024 * 1024; // 5 MB
  const ALLOWED_TYPES = ['image/jpeg', 'image/png', 'image/webp'];

  // ── DOM refs ──────────────────────────────────────────────
  const grid = document.getElementById('player-grid')!;
  const emptyState = document.getElementById('empty-state')!;
  const searchInput = document.getElementById('player-search') as HTMLInputElement;
  const form = document.getElementById('add-player-form') as HTMLFormElement;
  const nameInput = document.getElementById('player-name') as HTMLInputElement;
  const photoInput = document.getElementById('player-photo') as HTMLInputElement;
  const nameError = document.getElementById('name-error')!;
  const photoError = document.getElementById('photo-error')!;
  const photoPreview = document.getElementById('photo-preview')!;
  const photoPreviewImg = document.getElementById('photo-preview-img') as HTMLImageElement;

  let pendingPhotoDataUrl: string | null = null;

  const BASE = import.meta.env.BASE_URL;

  // ── Helpers ───────────────────────────────────────────────

  /** Format name BWF-style: first name(s) + LAST NAME in caps */
  function formatBWFName(fullName: string): string {
    const parts = fullName.trim().split(/\s+/);
    if (parts.length <= 1) return fullName.toUpperCase();
    const lastName = parts[parts.length - 1].toUpperCase();
    const firstNames = parts.slice(0, -1).join(' ');
    return `${firstNames} ${lastName}`;
  }

  /** Build a player card element */
  function createCardElement(player: Player): HTMLAnchorElement {
    const card = document.createElement('a');
    card.href = `${BASE}players/profile/?id=${player.id}`;
    card.className = 'player-card';

    const imgSrc = player.profilePicture ?? DEFAULT_PLACEHOLDER_IMAGE;
    const displayName = formatBWFName(player.name);

    card.innerHTML = `
      <div class="card-photo-wrapper">
        <img src="${imgSrc}" alt="${player.name} profile photo" class="card-photo" loading="lazy" />
      </div>
      <div class="card-body">
        <h3 class="card-name">${displayName}</h3>
        <span class="mmr-badge">${player.mmr} MMR</span>
        <p class="card-record">
          <span class="wins">${player.wins}W</span> / <span class="losses">${player.losses}L</span>
        </p>
      </div>
    `;
    return card;
  }

  /** Render the player grid, optionally filtered */
  function renderGrid(filter = '') {
    const data = loadData();
    const players = data.players;
    const query = filter.toLowerCase().trim();
    const filtered = query
      ? players.filter((p) => p.name.toLowerCase().includes(query))
      : players;

    // Clear existing cards (keep empty-state element)
    grid.querySelectorAll('.player-card').forEach((el) => el.remove());

    if (filtered.length === 0) {
      emptyState.textContent = query
        ? 'No players match your search.'
        : 'No players yet. Add your first player below!';
      emptyState.hidden = false;
    } else {
      emptyState.hidden = true;
      filtered.forEach((player) => {
        grid.appendChild(createCardElement(player));
      });
    }
  }

  /** Read a File as a base64 data URL */
  function readFileAsDataUrl(file: File): Promise<string> {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = () => resolve(reader.result as string);
      reader.onerror = () => reject(new Error('Failed to read file'));
      reader.readAsDataURL(file);
    });
  }

  // ── Event handlers ────────────────────────────────────────

  // Search
  searchInput.addEventListener('input', () => {
    renderGrid(searchInput.value);
  });

  // Photo preview + validation
  photoInput.addEventListener('change', async () => {
    photoError.textContent = '';
    photoPreview.hidden = true;
    pendingPhotoDataUrl = null;

    const file = photoInput.files?.[0];
    if (!file) return;

    if (!ALLOWED_TYPES.includes(file.type)) {
      photoError.textContent = 'Invalid format. Please upload a JPEG, PNG, or WebP image.';
      photoInput.value = '';
      return;
    }

    if (file.size > MAX_FILE_SIZE) {
      photoError.textContent = 'File too large. Maximum size is 5 MB.';
      photoInput.value = '';
      return;
    }

    try {
      pendingPhotoDataUrl = await readFileAsDataUrl(file);
      photoPreviewImg.src = pendingPhotoDataUrl;
      photoPreview.hidden = false;
    } catch {
      photoError.textContent = 'Could not read the image file.';
    }
  });

  // Form submission
  form.addEventListener('submit', (e) => {
    e.preventDefault();
    nameError.textContent = '';
    photoError.textContent = '';

    const name = nameInput.value.trim();
    if (!name) {
      nameError.textContent = 'Please enter a player name.';
      nameInput.focus();
      return;
    }

    const newPlayer: Player = {
      id: generateId(),
      name,
      profilePicture: pendingPhotoDataUrl,
      mmr: getInitialMMR(),
      wins: 0,
      losses: 0,
      createdAt: new Date().toISOString(),
    };

    const data = loadData();
    data.players.push(newPlayer);
    savePlayers(data.players);

    // Reset form
    form.reset();
    pendingPhotoDataUrl = null;
    photoPreview.hidden = true;

    // Re-render grid
    searchInput.value = '';
    renderGrid();
  });

  // ── Initial render ────────────────────────────────────────
  renderGrid();
</script>

<style is:global>
  .page-header {
    text-align: center;
    padding: 1.5rem 0 1rem;
  }

  .page-header h1 {
    font-size: 1.75rem;
    color: var(--color-primary, #1b5e20);
    margin-bottom: 0.25rem;
  }

  .subtitle {
    color: var(--color-text-light, #555);
    font-size: 1rem;
  }

  /* ── Search ─────────────────────────────────────────────── */
  .search-bar {
    max-width: 480px;
    margin: 0 auto 1.5rem;
  }

  .search-bar input {
    width: 100%;
    padding: 0.65rem 1rem;
    border: 1px solid var(--color-border, #dde5dd);
    border-radius: 8px;
    font-size: 0.95rem;
    outline: none;
    transition: border-color 0.2s;
  }

  .search-bar input:focus {
    border-color: var(--color-accent, #43a047);
    box-shadow: 0 0 0 3px rgba(67, 160, 71, 0.15);
  }

  /* ── Player grid ────────────────────────────────────────── */
  .player-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1.25rem;
    margin-bottom: 2.5rem;
  }

  .empty-state {
    grid-column: 1 / -1;
    text-align: center;
    color: var(--color-text-light, #555);
    padding: 2rem 0;
    font-size: 0.95rem;
  }

  /* Card styles */
  .player-card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface, #ffffff);
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    color: var(--color-text, #1a1a1a);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .player-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.12);
  }

  .card-photo-wrapper {
    background: linear-gradient(135deg, var(--color-primary, #1b5e20), var(--color-accent, #43a047));
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem 1rem 1rem;
  }

  .card-photo {
    width: 100px;
    height: 100px;
    object-fit: cover;
    border: 3px solid rgba(255, 255, 255, 0.9);
    background: var(--color-bg, #f5f7f5);
    border-radius: 0;
  }

  .card-body {
    padding: 1rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
  }

  .card-name {
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.3;
    margin: 0;
  }

  .mmr-badge {
    display: inline-block;
    background: var(--color-primary, #1b5e20);
    color: #fff;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.2rem 0.6rem;
    border-radius: 12px;
  }

  .card-record {
    font-size: 0.85rem;
    color: var(--color-text-light, #555);
    margin: 0;
  }

  .wins {
    color: var(--color-primary, #1b5e20);
    font-weight: 600;
  }

  .losses {
    color: #c62828;
    font-weight: 600;
  }

  /* ── Add Player form ────────────────────────────────────── */
  .add-player-section {
    max-width: 520px;
    margin: 0 auto;
    background: var(--color-surface, #fff);
    border: 1px solid var(--color-border, #dde5dd);
    border-radius: 12px;
    padding: 1.5rem;
  }

  .add-player-section h2 {
    font-size: 1.25rem;
    color: var(--color-primary, #1b5e20);
    margin-bottom: 1rem;
  }

  .form-group {
    margin-bottom: 1rem;
  }

  .form-group label {
    display: block;
    font-weight: 600;
    font-size: 0.9rem;
    margin-bottom: 0.35rem;
  }

  .optional {
    font-weight: 400;
    color: var(--color-text-light, #555);
    font-size: 0.85rem;
  }

  .form-group input[type='text'] {
    width: 100%;
    padding: 0.6rem 0.75rem;
    border: 1px solid var(--color-border, #dde5dd);
    border-radius: 6px;
    font-size: 0.95rem;
    outline: none;
    transition: border-color 0.2s;
  }

  .form-group input[type='text']:focus {
    border-color: var(--color-accent, #43a047);
    box-shadow: 0 0 0 3px rgba(67, 160, 71, 0.15);
  }

  .form-group input[type='file'] {
    font-size: 0.9rem;
  }

  .file-hint {
    display: block;
    font-size: 0.8rem;
    color: var(--color-text-light, #555);
    margin-top: 0.25rem;
  }

  .error-msg {
    display: block;
    color: #c62828;
    font-size: 0.85rem;
    min-height: 1.2em;
    margin-top: 0.25rem;
  }

  .photo-preview {
    margin-top: 0.5rem;
  }

  .photo-preview img {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--color-border, #dde5dd);
  }

  .btn-primary {
    background: var(--color-primary, #1b5e20);
    color: #fff;
    border: none;
    padding: 0.65rem 1.5rem;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
  }

  .btn-primary:hover {
    background: var(--color-primary-light, #2e7d32);
  }

  @media (max-width: 480px) {
    .player-grid {
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    }
  }
</style>
